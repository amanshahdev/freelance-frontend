# ─── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── MongoDB ────────────────────────────────────────────────────────────────────
# Replace <username>, <password>, and <cluster> with your MongoDB Atlas values,
# or use mongodb://localhost:27017/freelance_marketplace for a local instance.
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/freelance_marketplace?retryWrites=true&w=majority

# ─── JWT ────────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_very_long_random_secret_string
JWT_EXPIRES_IN=7d

# ─── CORS ───────────────────────────────────────────────────────────────────────
# The URL of your frontend (no trailing slash)
CLIENT_URL=http://localhost:3000
