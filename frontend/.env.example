# ── Frontend Environment Variables ─────────────────────────────────────────
# Copy this file to .env.local and fill in the values.
# IMPORTANT: All variables MUST start with REACT_APP_ to be accessible in React.

# Backend API base URL — no trailing slash, no /api suffix (added in api.js)
# Local development:
REACT_APP_API_URL=http://localhost:5000/api

# After deploying backend to Render, replace with your Render URL, e.g.:
# REACT_APP_API_URL=https://freelance-marketplace-api.onrender.com/api
